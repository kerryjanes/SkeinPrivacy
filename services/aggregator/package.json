{
  "name": "@weft/aggregator",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json --noEmit",
    "bundle": "esbuild src/cli.ts --bundle --platform=node --format=esm --target=node20 --outfile=dist/aggregator.mjs --banner:js=\"import{createRequire}from'module';const require=createRequire(import.meta.url);\"",
    "start": "tsx src/cli.ts",
    "smoke": "tsx src/m4smoke.ts",
    "test": "vitest run"
  },
  "dependencies": {
    "@noble/curves": "^1.6.0",
    "@weft/sdk": "workspace:*",
    "@solana-program/system": "^0.8.0",
    "@solana-program/token": "^0.14.0",
    "@solana/kit": "^6.10.0"
  },
  "devDependencies": {
    "esbuild": "^0.25.0",
    "@types/node": "^25.9.3",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
