# Weft SOL buyback & burn worker — /etc/weft/buyback.env
# Copy, fill in, and `WEFT_BUYBACK_ENABLE=1` only when you are ready to go live.
# The worker does nothing while WEFT_BUYBACK_ENABLE is unset/0.

WEFT_BUYBACK_ENABLE=0

# Mainnet RPC (Helius) and the reward mint (pump.fun CA).
WEFT_RPC=https://mainnet.helius-rpc.com/?api-key=REPLACE_WITH_HELIUS_KEY
WEFT_MINT=REPLACE_WITH_PUMPFUN_CA

# Hot wallet holding the SOL to spend. Fund it from the pump.fun buyback proceeds.
WEFT_BUYBACK_KEYPAIR=/etc/weft/buyback.json

# Node-payout pool that receives the node share of each buyback (DEg6vvw... on the relay).
WEFT_PAYOUT_WALLET=DEg6vvwNmkhaV9aTUaEUbhCG5AbFKNvGq8egiqScF1nq

# Split of bought $WEFT: node share vs burn (burn = 10000 - node). 7000 = 70% nodes / 30% burn.
WEFT_BUYBACK_NODE_BPS=7000

# Cadence + guards.
WEFT_BUYBACK_INTERVAL_MS=600000   # every 10 min
WEFT_BUYBACK_RESERVE_SOL=0.03     # always keep this for fees
WEFT_BUYBACK_MIN_SOL=0.05         # don't buy dust
WEFT_BUYBACK_MAX_SOL=5            # cap per cycle
WEFT_BUYBACK_SLIPPAGE_BPS=150
WEFT_BUYBACK_STORE=/var/lib/weft/buyback.json
# WEFT_JUP_API=https://lite-api.jup.ag/swap/v1
