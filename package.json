{
  "name": "weft",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.7.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "format": "prettier --write \"**/*.{ts,tsx,js,mjs,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,mjs,json,md}\"",
    "codegen": "pnpm --filter @weft/sdk generate",
    "build": "pnpm -r build"
  },
  "devDependencies": {
    "prettier": "^3.3.3",
    "typescript": "^5.7.3"
  }
}
