# Copy to `.env` and fill in. Never commit `.env`.

# Cluster: localnet | devnet | mainnet-beta
WEFT_CLUSTER=devnet

# RPC endpoint. The node registry uses compressed NFTs (M2+) which REQUIRE a
# DAS-API-capable RPC such as Helius. A plain Solana RPC will not work for cNFTs.
WEFT_RPC_URL=https://devnet.helius-rpc.com/?api-key=YOUR_HELIUS_KEY

# Helius API key (DAS API for the cNFT registry/indexer).
HELIUS_API_KEY=YOUR_HELIUS_KEY
